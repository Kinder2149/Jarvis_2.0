2026-03-07 14:07:20 - aiosqlite - DEBUG - executing functools.partial(<built-in method execute of sqlite3.Connection object at 0x0000020595C11990>, 'INSERT INTO library_documents \n                (id, category, name, icon, description, content, tags, agents, created_at, updated_at)\n                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)', ('fb8589f0-6765-422b-b924-627782908b45', 'methodologies', "Gestion d'erreurs Python", '⚠️', 'Bonnes pratiques try/except, logging, erreurs custom', '# Gestion d\'erreurs Python\n\n## Try/Except de base\ntry:\n    result = risky_operation()\nexcept ValueError as e:\n    print(f"Erreur: {e}")\nexcept Exception as e:\n    print(f"Erreur inattendue: {e}")\nfinally:\n    cleanup()\n\n## Erreurs custom\nclass ValidationError(Exception):\n    pass\n\ndef validate(data):\n    if not data:\n        raise ValidationError("Data cannot be empty")\n\n## Logging\nimport logging\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\ntry:\n    result = operation()\nexcept Exception as e:\n    logger.error(f"Operation failed: {e}", exc_info=True)\n    raise\n\n## Bonnes pratiques\n# ✅ Spécifique\ntry:\n    int("abc")\nexcept ValueError:\n    pass\n\n# ❌ Trop large\ntry:\n    int("abc")\nexcept Exception:\n    pass', '["python", "errors", "best-practices"]', '["CODEUR", "BASE"]', '2026-03-07T14:07:20.130834', '2026-03-07T14:07:20.130834'))
