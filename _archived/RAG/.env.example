# Configuration RAG pour JARVIS 2.0

# Nom de la collection ChromaDB
RAG_COLLECTION_NAME=jarvis_library

# Répertoire de persistance de la base de données vectorielle
RAG_PERSIST_DIR=./data/rag_db

# Modèle d'embedding Sentence Transformers
# Options recommandées :
# - all-MiniLM-L6-v2 (anglais, léger, rapide)
# - paraphrase-multilingual-MiniLM-L12-v2 (multilingue, français)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Taille des chunks en caractères
RAG_CHUNK_SIZE=1000

# Chevauchement entre chunks en caractères
RAG_CHUNK_OVERLAP=200

# Device pour les embeddings (cuda, cpu, ou None pour auto-detect)
RAG_DEVICE=cpu
