# Copiez ce fichier en ".env" et renseignez vos valeurs privées
# Ne commitez jamais le fichier .env

# ============================================
# PROVIDER GEMINI (Google AI)
# ============================================

# Clé API Gemini (obtenir sur https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Modèle par défaut
GEMINI_MODEL=gemini-2.5-pro

# ============================================
# CONFIGURATION AGENTS → MODÈLES GEMINI
# ============================================

# Configuration Tier 1 Gemini validée (7 mars 2026)
# Tous les agents utilisent Gemini exclusivement
# Équipe 5 agents : JARVIS_Maître, ARCHITECTE, CODEUR, TESTEUR, VALIDATEUR
# BASE conservé comme template uniquement (non utilisé workflow)

# JARVIS_Maître : Orchestrateur, cycle ARRF complet, reconnaissance phases
JARVIS_MAITRE_PROVIDER=gemini
JARVIS_MAITRE_MODEL=gemini-2.5-pro

# ARCHITECTE : Conception architecture AVANT code (Analyse + Réflexion)
ARCHITECTE_PROVIDER=gemini
ARCHITECTE_MODEL=gemini-2.5-pro

# CODEUR : Génération code uniquement (Fixation)
CODEUR_PROVIDER=gemini
CODEUR_MODEL=gemini-2.5-pro

# TESTEUR : Génération tests exhaustifs (Réflexion + Fixation)
TESTEUR_PROVIDER=gemini
TESTEUR_MODEL=gemini-2.0-flash

# VALIDATEUR : Contrôle qualité multi-niveaux (Remise en Question)
VALIDATEUR_PROVIDER=gemini
VALIDATEUR_MODEL=gemini-3.1-pro-preview

# BASE : Template pour créer nouveaux agents (non utilisé workflow actif)
BASE_PROVIDER=gemini
BASE_MODEL=gemini-2.5-pro

# ============================================
# SÉCURITÉ & CONTEXTE
# ============================================

# Limite de tokens pour le contexte projet (éviter dépassement)
MAX_CONTEXT_TOKENS=50000

# Activer la redaction de données sensibles (API keys, secrets)
ENABLE_REDACTION=true
